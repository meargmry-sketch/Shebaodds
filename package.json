// ─── REJECT TRANSACTION ───
bot.onText(/\/reject (.+)/, async (msg, match) => {
  const chatId = msg.chat.id;
  if (chatId !== config.adminId) {
    bot.sendMessage(chatId, '⛔ Unauthorized');
    return;
  }

  const id = match[1];
  try {
    const transaction = await Transaction.findById(id);
    if (!transaction) {
      bot.sendMessage(chatId, '❌ Transaction not found.');
      return;
    }

    if (transaction.status !== 'pending') {
      bot.sendMessage(chatId, '❌ Transaction already processed.');
      return;
    }

    transaction.status = 'rejected';
    await transaction.save();

    bot.sendMessage(chatId, `❌ Transaction ${transaction._id} rejected!`);
    
    bot.sendMessage(transaction.userId, `
❌ *Transaction Rejected*

Transaction ID: ${transaction._id}
Amount: ${formatCurrency(transaction.amount)} ETB

Please contact support for more information.
    `, { parse_mode: 'Markdown' });

  } catch (error) {
    logger.error('Reject transaction error:', error);
    bot.sendMessage(chatId, '❌ Error rejecting transaction.');
  }
});

// ─── BROADCAST ───
bot.onText(/\/broadcast (.+)/, async (msg, match) => {
  const chatId = msg.chat.id;
  if (chatId !== config.adminId) {
    bot.sendMessage(chatId, '⛔ Unauthorized');
    return;
  }

  const message = match[1];
  let sent = 0;
  let failed = 0;

  try {
    const users = await User.find({});

    for (const user of users) {
      try {
        await bot.sendMessage(user.telegramId, `
📢 *SHEBAODDS Announcement*

${message}

---
_Smart Bets. Real Wins._ 🦁
        `, { parse_mode: 'Markdown' });
        sent++;
      } catch (error) {
        failed++;
      }
      // Rate limiting
      await new Promise(resolve => setTimeout(resolve, 100));
    }

    bot.sendMessage(chatId, `
📢 *Broadcast Complete!*

✅ Sent: ${sent}
❌ Failed: ${failed}
👥 Total Users: ${users.length}
    `, { parse_mode: 'Markdown' });

  } catch (error) {
    logger.error('Broadcast error:', error);
    bot.sendMessage(chatId, '❌ Error sending broadcast.');
  }
});

// ─── STATUS COMMAND ───
bot.onText(/\/status/, async (msg) => {
  const chatId = msg.chat.id;
  
  const status = {
    uptime: process.uptime(),
    memory: process.memoryUsage(),
    users: await User.countDocuments(),
    transactions: await Transaction.countDocuments(),
    version: '3.0.0'
  };

  const message = `
🦁 *SHEBAODDS Status*

📅 Version: ${status.version}
⏱️ Uptime: ${Math.floor(status.uptime / 3600)}h ${Math.floor((status.uptime % 3600) / 60)}m
👥 Users: ${status.users}
💳 Transactions: ${status.transactions}

💾 Memory:
- RSS: ${Math.round(status.memory.rss / 1024 / 1024)} MB
- Heap: ${Math.round(status.memory.heapUsed / 1024 / 1024)} MB

🟢 Status: *Online*
  `;

  bot.sendMessage(chatId, message, { parse_mode: 'Markdown' });
});

