// Format currency
const formatCurrency = (amount) => {
  return amount.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 2 });
};

// Get user from database or create
const getOrCreateUser = async (telegramId, userData) => {
  try {
    let user = await User.findOne({ telegramId });
    if (!user) {
      user = new User({
        telegramId,
        username: userData.username || `user_${telegramId}`,
        firstName: userData.firstName || 'User',
        lastName: userData.lastName || '',
        email: `${telegramId}@shebaodds.com`,
        role: telegramId === config.adminId ? 'admin' : 'user',
        settings: {
          language: 'en',
          notifications: true,
          taxPreference: 'automatic'
        }
      });
      await user.save();
      logger.info(`New user created: ${user.username}`);
    }
    return user;
  } catch (error) {
    logger.error('Error getting/creating user:', error);
    return null;
  }
};

// Get user wallet
const getUserWallet = async (userId) => {
  try {
    let wallet = await Wallet.findOne({ userId });
    if (!wallet) {
      wallet = new Wallet({
        userId,
        balance: 1000,
        bonusBalance: 0,
        currency: 'ETB',
        totalDeposited: 0,
        totalWithdrawn: 0,
        totalWon: 0,
        totalLost: 0,
        totalTaxPaid: 0
      });
      await wallet.save();
    }
    return wallet;
  } catch (error) {
    logger.error('Error getting wallet:', error);
    return null;
  }
};

// Create transaction
const createTransaction = async (data) => {
  try {
    const transaction = new Transaction(data);
    await transaction.save();
    return transaction;
  } catch (error) {
    logger.error('Error creating transaction:', error);
    return null;
  }
};

// Update wallet balance
const updateWalletBalance = async (userId, amount, type, metadata = {}) => {
  try {
    const wallet = await Wallet.findOne({ userId });
    if (!wallet) return null;

    const oldBalance = wallet.balance;
    wallet.balance += amount;
    wallet.updatedAt = new Date();

    if (amount > 0) {
      wallet.totalWon += amount;
    } else {
      wallet.totalLost += Math.abs(amount);
    }

    await wallet.save();

    // Create transaction record
    await createTransaction({
      userId,
      type,
      amount,
      oldBalance,
      newBalance: wallet.balance,
      currency: 'ETB',
      status: 'completed',
      metadata,
      description: metadata.description || `${type} transaction`
    });

    return wallet;
  } catch (error) {
    logger.error('Error updating wallet:', error);
    return null;
  }
};

