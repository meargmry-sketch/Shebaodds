// ─── WITHDRAW TELEBIRR ───
async function showWithdrawTelebirr(chatId) {
  const message = `
📱 *Withdraw via Telebirr*

*Format:* /withdraw_telebirr [ticket] [amount]

*Example:*
/withdraw_telebirr ABC123 50

📌 *Note:*
- Processing time: 5-10 minutes
- Min withdrawal: 10 ETB
- Fee: 5 ETB
  `;

  bot.sendMessage(chatId, message, { parse_mode: 'Markdown' });
}

// ─── WITHDRAW TELEBIRR CONFIRM ───
bot.onText(/\/withdraw_telebirr (.+) (\d+)/, async (msg, match) => {
  const chatId = msg.chat.id;
  const userId = msg.from.id;
  const ticket = match[1];
  const amount = parseInt(match[2]);

  try {
    const wallet = await getUserWallet(userId);
    if (!wallet) {
      bot.sendMessage(chatId, '❌ Error accessing wallet.');
      return;
    }

    const totalAmount = amount + 5; // With fee

    if (totalAmount > wallet.balance) {
      bot.sendMessage(chatId, `❌ Insufficient balance. Your balance is ${formatCurrency(wallet.balance)} ETB`);
      return;
    }

    if (amount < 10) {
      bot.sendMessage(chatId, '❌ Minimum withdrawal is 10 ETB');
      return;
    }

    const updatedWallet = await updateWalletBalance(
      userId,
      -totalAmount,
      'withdrawal',
      {
        method: 'telebirr',
        ticket,
        amount,
        fee: 5
      }
    );

    if (!updatedWallet) {
      bot.sendMessage(chatId, '❌ Error processing withdrawal. Please try again.');
      return;
    }

    bot.sendMessage(chatId, `
✅ *Withdrawal Request Submitted!*

💰 Amount: ${formatCurrency(amount)} ETB
📱 Method: Telebirr
🎫 Ticket: ${ticket}
💳 Fee: 5 ETB
💰 New Balance: ${formatCurrency(updatedWallet.balance)} ETB

⏱️ Processing time: 5-10 minutes
You will be notified when complete.
    `, { parse_mode: 'Markdown' });

    // Notify admin
    bot.sendMessage(config.adminId, `
📝 *Withdrawal Request*

👤 User: ${userId}
💰 Amount: ${formatCurrency(amount)} ETB
📱 Method: Telebirr
🎫 Ticket: ${ticket}
💳 Fee: 5 ETB
⏱️ Pending approval
    `, { parse_mode: 'Markdown' });

    logger.info(`Withdrawal: ${userId} | ${amount} ETB | ${ticket}`);

  } catch (error) {
    logger.error('Withdrawal error:', error);
    bot.sendMessage(chatId, '❌ Error processing withdrawal. Please try again.');
  }
});

