// ─── ADMIN COMMANDS ───
bot.onText(/\/admin/, (msg) => {
  const chatId = msg.chat.id;
  if (chatId !== config.adminId) {
    bot.sendMessage(chatId, '⛔ Unauthorized. Only admin can access this.');
    return;
  }

  bot.sendMessage(chatId, '👑 *Admin Panel*', {
    parse_mode: 'Markdown',
    reply_markup: {
      inline_keyboard: [
        [{ text: '📊 Stats', callback_data: 'admin_stats' }],
        [{ text: '💰 Total Balance', callback_data: 'admin_balance' }],
        [{ text: '👥 Users', callback_data: 'admin_users' }],
        [{ text: '📝 Pending Deposits', callback_data: 'admin_deposits' }],
        [{ text: '📝 Pending Withdrawals', callback_data: 'admin_withdrawals' }],
        [{ text: '📢 Broadcast', callback_data: 'admin_broadcast' }]
      ]
    }
  });
});

// ─── ADMIN STATS ───
bot.on('callback_query', async (query) => {
  if (query.data.startsWith('admin_')) {
    const chatId = query.message.chat.id;
    if (chatId !== config.adminId) {
      bot.answerCallbackQuery(query.id, { text: 'Unauthorized' });
      return;
    }

    switch (query.data) {
      case 'admin_stats': {
        try {
          const totalUsers = await User.countDocuments();
          const totalWallets = await Wallet.countDocuments();
          const walletData = await Wallet.aggregate([
            { $group: {
              _id: null,
              totalBalance: { $sum: '$balance' },
              totalBonus: { $sum: '$bonusBalance' },
              totalDeposited: { $sum: '$totalDeposited' },
              totalWithdrawn: { $sum: '$totalWithdrawn' },
              totalWon: { $sum: '$totalWon' },
              totalLost: { $sum: '$totalLost' },
              totalTaxPaid: { $sum: '$totalTaxPaid' }
            }}
          ]);
          
          const stats = walletData[0] || {};
          
          bot.sendMessage(chatId, `
📊 *SHEBAODDS Statistics*

👥 Users: *${totalUsers}*
👛 Wallets: *${totalWallets}*

💰 Total Balance: *${formatCurrency(stats.totalBalance || 0)} ETB*
🎁 Total Bonus: *${formatCurrency(stats.totalBonus || 0)} ETB*

📈 Total Deposited: *${formatCurrency(stats.totalDeposited || 0)} ETB*
📉 Total Withdrawn: *${formatCurrency(stats.totalWithdrawn || 0)} ETB*

🏆 Total Won: *${formatCurrency(stats.totalWon || 0)} ETB*
📉 Total Lost: *${formatCurrency(stats.totalLost || 0)} ETB*

📊 Platform Profit: *${formatCurrency((stats.totalLost || 0) - (stats.totalWon || 0))} ETB*
💰 Tax Collected: *${formatCurrency(stats.totalTaxPaid || 0)} ETB*
          `, { parse_mode: 'Markdown' });
          break;
        } catch (error) {
          logger.error('Admin stats error:', error);
          bot.sendMessage(chatId, '❌ Error fetching stats.');
        }
        break;
      }

      case 'admin_balance': {
        try {
          const topUsers = await Wallet.find()
            .sort({ balance: -1 })
            .limit(10)
            .populate('userId', 'username firstName');

          let msg = '💰 *Top 10 Balances*\n\n';
          topUsers.forEach((wallet, i) => {
            const user = wallet.userId;
            const name = user ? user.username || user.firstName : 'Unknown';
            msg += `${i+1}. ${name}: ${formatCurrency(wallet.balance)} ETB\n`;
          });
          bot.sendMessage(chatId, msg, { parse_mode: 'Markdown' });
        } catch (error) {
          logger.error('Admin balance error:', error);
          bot.sendMessage(chatId, '❌ Error fetching balances.');
        }
        break;
      }

      case 'admin_users': {
        try {
          const totalUsers = await User.countDocuments();
          const activeUsers = await User.countDocuments({ 
            'settings.notifications': true 
          });
          const newUsersToday = await User.countDocuments({
            createdAt: { $gte: new Date(new Date().setHours(0,0,0,0)) }
          });

          bot.sendMessage(chatId, `
👥 *User Statistics*

Total Users: *${totalUsers}*
Active Users: *${activeUsers}*
New Today: *${newUsersToday}*

📊 *User Growth*
Today: ${newUsersToday}
This Week: ${await User.countDocuments({ 
            createdAt: { $gte: new Date(new Date().setDate(new Date().getDate() - 7)) }
          })}
This Month: ${await User.countDocuments({
            createdAt: { $gte: new Date(new Date().setDate(1)) }
          })}
          `, { parse_mode: 'Markdown' });
        } catch (error) {
          logger.error('Admin users error:', error);
          bot.sendMessage(chatId, '❌ Error fetching user stats.');
        }
        break;
      }

      case 'admin_deposits': {
        try {
          const pendingDeposits = await Transaction.find({
            type: 'deposit',
            status: 'pending'
          }).limit(10);

          if (pendingDeposits.length === 0) {
            bot.sendMessage(chatId, '📝 No pending deposits.');
            return;
          }

          let msg = '📝 *Pending Deposits*\n\n';
          pendingDeposits.forEach((tx, i) => {
            msg += `${i+1}. User: ${tx.userId} | ${formatCurrency(tx.amount)} ETB\n`;
            msg += `   📅 ${moment(tx.createdAt).fromNow()}\n`;
          });
          msg += `\nUse /approve_deposit [id] or /reject_deposit [id]`;
          bot.sendMessage(chatId, msg, { parse_mode: 'Markdown' });
        } catch (error) {
          logger.error('Admin deposits error:', error);
          bot.sendMessage(chatId, '❌ Error fetching deposits.');
        }
        break;
      }

      case 'admin_withdrawals': {
        try {
          const pendingWithdrawals = await Transaction.find({
            type: 'withdrawal',
            status: 'pending'
          }).limit(10);

          if (pendingWithdrawals.length === 0) {
            bot.sendMessage(chatId, '📝 No pending withdrawals.');
            return;
          }

          let msg = '📝 *Pending Withdrawals*\n\n';
          pendingWithdrawals.forEach((tx, i) => {
            msg += `${i+1}. User: ${tx.userId} | ${formatCurrency(tx.amount)} ETB\n`;
            msg += `   📅 ${moment(tx.createdAt).fromNow()}\n`;
          });
          msg += `\nUse /approve_withdraw [id] or /reject_withdraw [id]`;
          bot.sendMessage(chatId, msg, { parse_mode: 'Markdown' });
        } catch (error) {
          logger.error('Admin withdrawals error:', error);
          bot.sendMessage(chatId, '❌ Error fetching withdrawals.');
        }
        break;
      }

      case 'admin_broadcast': {
        bot.sendMessage(chatId, '📢 *Broadcast Message*\n\nSend a message to all users:\n/broadcast [message]', { parse_mode: 'Markdown' });
        break;
      }
    }

    bot.answerCallbackQuery(query.id);
  }
});

// ─── APPROVE DEPOSIT ───
bot.onText(/\/approve_deposit (.+)/, async (msg, match) => {
  const chatId = msg.chat.id;
  if (chatId !== config.adminId) {
    bot.sendMessage(chatId, '⛔ Unauthorized');
    return;
  }

  const id = match[1];
  try {
    const transaction = await Transaction.findById(id);
    if (!transaction) {
      bot.sendMessage(chatId, '❌ Transaction not found.');
      return;
    }

    if (transaction.status !== 'pending') {
      bot.sendMessage(chatId, '❌ Transaction already processed.');
      return;
    }

    transaction.status = 'completed';
    await transaction.save();

    // Update wallet
    const wallet = await getUserWallet(transaction.userId);
    if (wallet) {
      wallet.balance += transaction.amount;
      wallet.totalDeposited += transaction.amount;
      await wallet.save();
    }

    bot.sendMessage(chatId, `✅ Deposit ${transaction._id} approved!`);
    
    // Notify user
    bot.sendMessage(transaction.userId, `
✅ *Deposit Approved!*

💰 Amount: ${formatCurrency(transaction.amount)} ETB
📅 Approved: ${moment().format('YYYY-MM-DD HH:mm')}

Your balance has been updated.
Happy betting! 🎰
    `, { parse_mode: 'Markdown' });

  } catch (error) {
    logger.error('Approve deposit error:', error);
    bot.sendMessage(chatId, '❌ Error approving deposit.');
  }
});

