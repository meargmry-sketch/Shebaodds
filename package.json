// ─── HANDLE GAME PLAY ───
async function handleGamePlay(chatId, userId, gameName, amount, params = {}) {
  try {
    // Validate amount
    if (isNaN(amount) || amount < 1) {
      bot.sendMessage(chatId, '❌ Please enter a valid bet amount (minimum 1 ETB)');
      return;
    }

    // Find game
    const game = getGame(gameName);
    if (!game) {
      bot.sendMessage(chatId, '❌ Game not found. Use /games to see available games.');
      return;
    }

    // Get user and wallet
    const user = await getOrCreateUser(userId, { 
      firstName: 'User',
      username: `user_${userId}` 
    });
    
    const wallet = await getUserWallet(userId);
    if (!wallet) {
      bot.sendMessage(chatId, '❌ Error accessing wallet.');
      return;
    }

    // Check balance
    if (amount > wallet.balance) {
      bot.sendMessage(chatId, `❌ Insufficient balance. Your balance is ${formatCurrency(wallet.balance)} ETB`);
      return;
    }

    // Validate min/max bet
    if (amount < game.minBet) {
      bot.sendMessage(chatId, `❌ Minimum bet for ${game.name} is ${game.minBet} ETB`);
      return;
    }

    if (amount > game.maxBet) {
      bot.sendMessage(chatId, `❌ Maximum bet for ${game.name} is ${game.maxBet} ETB`);
      return;
    }

    // Execute game
    const logic = gameLogic[game.id] || gameLogic.default;
    const result = logic(amount, params);

    // Update wallet
    const updatedWallet = await updateWalletBalance(
      userId,
      result.profit,
      'game',
      {
        gameId: game.id,
        gameName: game.name,
        bet: amount,
        result: result.result,
        details: result.details
      }
    );

    if (!updatedWallet) {
      bot.sendMessage(chatId, '❌ Error updating balance. Please try again.');
      return;
    }

    // Format result message
    const isWin = result.result === 'win';
    const isPush = result.result === 'push';
    const emoji = isWin ? '🎉' : isPush ? '⚖️' : '❌';
    const resultText = isWin ? 'WIN' : isPush ? 'PUSH' : 'LOSE';
    const profitText = result.profit > 0 ? `+${formatCurrency(result.profit)}` : formatCurrency(result.profit);

    // Format details
    let detailsText = '';
    if (result.details) {
      if (game.id === 'dice') {
        detailsText = `🎲 Player: ${result.details.playerRoll} | House: ${result.details.houseRoll}`;
      } else if (game.id === 'coinflip') {
        detailsText = `🪙 Result: ${result.details.result === 'heads' ? '👑 Heads' : '🦅 Tails'}`;
      } else if (game.id === 'roulette') {
        const color = result.details.number === 0 ? '🟢 Green' : result.details.isRed ? '🔴 Red' : '⚫ Black';
        detailsText = `🎡 Number: ${result.details.number} | ${color}`;
      } else if (game.id === 'slot') {
        detailsText = `🎰 ${result.details.reels?.join(' | ')} | ${result.details.multiplier ? `x${result.details.multiplier}` : 'Try again'}`;
      } else if (game.id === 'blackjack') {
        detailsText = `🃏 You: ${result.details.playerScore} | Dealer: ${result.details.dealerScore}`;
      } else if (game.id === 'aviator' || game.id === 'crash') {
        detailsText = `📈 Crashed at ${result.details.crashPoint?.toFixed(2)}x | Cashed out at ${result.details.multiplier?.toFixed(2) || '0'}x`;
      } else if (game.id === 'mines') {
        detailsText = result.details.hitMine ? '💣 Hit a mine!' : '💰 Safe!';
      } else {
        detailsText = JSON.stringify(result.details);
      }
    }

    const message = `
${emoji} *${resultText}*

🎮 *${game.icon} ${game.name}*
💰 Bet: *${formatCurrency(amount)} ETB*
📊 Profit: *${profitText} ETB*
💰 New Balance: *${formatCurrency(updatedWallet.balance)} ETB*

📝 ${detailsText || 'Good game!'}
    `;

    bot.sendMessage(chatId, message, {
      parse_mode: 'Markdown',
      reply_markup: {
        inline_keyboard: [
          [{ text: '🔄 Play Again', callback_data: `play_${game.id}_${amount}` }],
          [{ text: '💰 Balance', callback_data: 'balance' }]
        ]
      }
    });

    // Log the game
    logger.info(`Game played: ${game.id} | User: ${userId} | Bet: ${amount} | Result: ${result.result}`);

  } catch (error) {
    logger.error('Game play error:', error);
    bot.sendMessage(chatId, '❌ An error occurred while playing. Please try again.');
  }
}

// ─── CALLBACK QUERIES ───
bot.on('callback_query', async (query) => {
  const chatId = query.message.chat.id;
  const userId = query.from.id;
  const data = query.data;

  try {
    switch (data) {
      case 'balance':
        bot.emit('text', { chat: { id: chatId }, from: { id: userId }, text: '/balance' });
        break;

      case 'quick_game':
        await showQuickGameMenu(chatId);
        break;

      case 'history':
        await showHistory(chatId, userId);
        break;

      case 'promotions':
        await showPromotions(chatId);
        break;

      case 'support':
        await showSupport(chatId);
        break;

      case 'vip':
        await showVIP(chatId, userId);
        break;

      case 'deposit':
        await showDeposit(chatId);
        break;

      case 'withdraw':
        await showWithdraw(chatId);
        break;

      case 'deposit_telebirr':
        await showDepositTelebirr(chatId);
        break;

      case 'deposit_cbe':
        await showDepositCBE(chatId);
        break;

      case 'withdraw_telebirr':
        await showWithdrawTelebirr(chatId);
        break;

      case 'withdraw_cbe':
        await showWithdrawCBE(chatId);
        break;

      case 'live_chat':
        bot.sendMessage(chatId, '💬 *Live Chat*\n\nPlease wait for an agent to connect...');
        break;

      default:
        if (data.startsWith('play_')) {
          const parts = data.split('_');
          const gameId = parts[1];
          const amount = parseInt(parts[2]);
          bot.emit('text', { 
            chat: { id: chatId }, 
            from: { id: userId }, 
            text: `/play ${gameId} ${amount}` 
          });
        } else if (data.startsWith('quick_')) {
          const parts = data.split('_');
          const gameId = parts[1];
          const amount = parts[2] ? parseInt(parts[2]) : 10;
          bot.emit('text', { 
            chat: { id: chatId }, 
            from: { id: userId }, 
            text: `/play ${gameId} ${amount}` 
          });
        }
    }

    bot.answerCallbackQuery(query.id);

  } catch (error) {
    logger.error('Callback error:', error);
    bot.answerCallbackQuery(query.id, { text: 'Error processing request' });
  }
});

