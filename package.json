// ─── VIP ───
async function showVIP(chatId, userId) {
  try {
    const transactions = await Transaction.find({ userId });
    const gamesPlayed = transactions.filter(t => t.type === 'game').length;
    const totalWagered = transactions
      .filter(t => t.type === 'game' && t.amount < 0)
      .reduce((sum, t) => sum + Math.abs(t.amount), 0);
    
    let level = 1;
    let nextLevel = 50;
    let nextLevelWagered = 1000;
    
    if (gamesPlayed >= 1000 && totalWagered >= 50000) { 
      level = 4; 
      nextLevel = Infinity;
      nextLevelWagered = Infinity;
    } else if (gamesPlayed >= 500 && totalWagered >= 20000) { 
      level = 3; 
      nextLevel = 1000;
      nextLevelWagered = 50000;
    } else if (gamesPlayed >= 100 && totalWagered >= 5000) { 
      level = 2; 
      nextLevel = 500;
      nextLevelWagered = 20000;
    } else { 
      level = 1; 
      nextLevel = 50;
      nextLevelWagered = 1000;
    }

    const benefits = {
      1: '5% bonus on deposits, 10% cashback, Basic support',
      2: '10% bonus on deposits, 15% cashback, Priority support',
      3: '15% bonus on deposits, 20% cashback, VIP support, Exclusive games',
      4: '20% bonus on deposits, 25% cashback, 24/7 VIP support, All games, Personal manager'
    };

    const message = `
👑 *VIP Program*

Your Level: *${level}* 👑
Games Played: ${gamesPlayed}
Total Wagered: ${formatCurrency(totalWagered)} ETB

*Benefits:*
${benefits[level]}

${gamesPlayed >= nextLevel ? '✅ You are at max level!' : `🎯 Next level: ${nextLevel} games or ${formatCurrency(nextLevelWagered)} ETB wagered`}

Keep playing to level up! 🚀
    `;

    bot.sendMessage(chatId, message, { parse_mode: 'Markdown' });

  } catch (error) {
    logger.error('VIP error:', error);
    bot.sendMessage(chatId, '❌ Could not fetch VIP info. Please try again.');
  }
}

