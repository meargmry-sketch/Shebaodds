// ─── HISTORY ───
async function showHistory(chatId, userId) {
  try {
    const transactions = await Transaction.find({ userId })
      .sort({ createdAt: -1 })
      .limit(20);

    if (!transactions || transactions.length === 0) {
      bot.sendMessage(chatId, '📊 No game history yet. Start playing to see your stats!');
      return;
    }

    let message = '📊 *Recent Activity*\n\n';
    let totalWon = 0;
    let totalLost = 0;

    transactions.forEach((tx, i) => {
      const emoji = tx.amount > 0 ? '✅' : '❌';
      const amount = tx.amount > 0 ? `+${formatCurrency(tx.amount)}` : formatCurrency(tx.amount);
      const type = tx.type === 'game' ? '🎮' : tx.type === 'deposit' ? '💰' : '🏦';
      const date = moment(tx.createdAt).fromNow();
      
      message += `${i+1}. ${emoji} ${type} ${amount} ETB (${date})\n`;
      
      if (tx.amount > 0) totalWon += tx.amount;
      else totalLost += Math.abs(tx.amount);
    });

    const net = totalWon - totalLost;
    const netText = net >= 0 ? `+${formatCurrency(net)}` : formatCurrency(net);

    message += `\n📈 *Summary:* Won ${formatCurrency(totalWon)} ETB | Lost ${formatCurrency(totalLost)} ETB | Net ${netText} ETB`;

    bot.sendMessage(chatId, message, { parse_mode: 'Markdown' });

  } catch (error) {
    logger.error('History error:', error);
    bot.sendMessage(chatId, '❌ Could not fetch history. Please try again.');
  }
}

