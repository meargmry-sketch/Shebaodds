  };

  // ─── INIT GAME STATE ───
  const initGameState = (gameId) => {
    const newState = { ...gameState };
    const defaultStates = {
      'aviator': { multiplier: 1.0, gameStarted: false, crashed: false, history: [] },
      'dice': { playerRoll: null, houseRoll: null, result: null },
      'coinflip': { side: 'heads', result: null, flipping: false },
      'plinko': { rows: 12, ballPosition: null, multiplier: null },
      'blackjack': { deck: [], playerHand: [], dealerHand: [], playing: false },
      'roulette': { bet: 'red', number: null, spinning: false },
      'mines': { revealed: [], mines: [], gameOver: false },
      'crash': { multiplier: 1.0, gameStarted: false, crashed: false },
      'tower': { currentLevel: 1, maxLevel: 10, gameOver: false },
      'keno': { picks: [], drawn: [], gameOver: false },
      'baccarat': { player: 0, banker: 0, tie: false, gameOver: false },
      'slot': { reels: ['🎰', '🎰', '🎰'], spinning: false }
    };
    
    newState[gameId] = defaultStates[gameId] || {};
    setGameState(newState);
  };

  // ─── UPDATE GAME VIEW ───
  const updateGameView = (gameId, data) => {
    const details = data.details || {};
    
    switch (gameId) {
      case 'dice':
        if (details.playerRoll !== undefined) {
          document.getElementById('dicePlayerRoll')?.textContent = getDiceEmoji(details.playerRoll);
          document.getElementById('diceHouseRoll')?.textContent = getDiceEmoji(details.houseRoll);
        }
        break;
      case 'coinflip':
        const result = details.result || 'heads';
        document.getElementById('coinResult')?.textContent = result === 'heads' ? '👑' : '🦅';
        break;
      case 'roulette':
        if (details.number !== undefined) {
          const number = details.number;
          const isRed = details.isRed;
          const color = number === 0 ? 'green' : isRed ? 'red' : 'black';
          document.getElementById('rouletteNumber')?.textContent = number;
          document.getElementById('rouletteNumber')?.style.color = color;
        }
        break;
      case 'slot':
        if (details.reels) {
          document.getElementById('slot1')?.textContent = details.reels[0];
          document.getElementById('slot2')?.textContent = details.reels[1];
          document.getElementById('slot3')?.textContent = details.reels[2];
        }
        break;
      default:
        break;
    }
  };

  const getDiceEmoji = (value) => {
    return ['⚀', '⚁', '⚂', '⚃', '⚄', '⚅'][value - 1] || '🎲';
  };

  // ─── TOAST NOTIFICATIONS ───
  const showToast = (message, type = 'info') => {
    const toast = document.createElement('div');
    toast.className = `toast toast-${type}`;
    toast.textContent = message;
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 3000);
  };

  // ─── TOGGLE FAVORITE ───
  const toggleFavorite = (gameId) => {
    setFavorites(prev => {
      const newFavorites = prev.includes(gameId) 
        ? prev.filter(id => id !== gameId) 
        : [...prev, gameId];
      localStorage.setItem('shebaodds_favorite_games', JSON.stringify(newFavorites));
      return newFavorites;
    });
  };

  // ─── RENDER GAMES ───
  const renderGames = () => {
    const categories = ['crash', 'classic', 'table', 'slots', 'sports', 'special'];
    const categoryLabels = {
      crash: language === 'am' ? '✈️ ክራሽ' : '✈️ Crash',
      classic: language === 'am' ? '♠️ ክላሲክ' : '♠️ Classic',
      table: language === 'am' ? '🎲 ጠረጴዛ' : '🎲 Table',
      slots: language === 'am' ? '🎰 ስሎቶች' : '🎰 Slots',
      sports: language === 'am' ? '⚽ ስፖርት' : '⚽ Sports',
      special: language === 'am' ? '✨ ልዩ' : '✨ Special'
    };

    // Get favorite games first
    const favoriteGames = GAMES.filter(g => favorites.includes(g.id));
    
    // Then the rest
    const otherGames = GAMES.filter(g => !favorites.includes(g.id));

    return (
      <>
        {/* Favorite Games Section */}
        {favoriteGames.length > 0 && (
          <div className="game-category">
            <h3 className="category-title">⭐ {language === 'am' ? 'የሚወዷቸው ጨዋታዎች' : 'Favorite Games'}</h3>
            <div className="game-grid">
              {favoriteGames.map(game => renderGameCard(game))}
            </div>
          </div>
        )}

        {/* All Games by Category */}
        {categories.map(category => {
          const gamesInCat = otherGames.filter(g => g.cat === category);
          if (gamesInCat.length === 0) return null;

          return (
            <div key={category} className="game-category">
              <h3 className="category-title">
                {categoryLabels[category]} <small>{gamesInCat.length} {language === 'am' ? 'ጨዋታዎች' : 'games'}</small>
              </h3>
              <div className="game-grid">
                {gamesInCat.map(game => renderGameCard(game))}
              </div>
            </div>
          );
        })}
      </>
    );
  };

  const renderGameCard = (game) => (
    <div 
      key={game.id} 
      className={`game-card ${selectedGame?.id === game.id ? 'active' : ''}`}
      onClick={() => openGame(game)}
    >
      {game.id === 'aviator' && <span className="badge live">LIVE</span>}
      {['slot', 'megaball', 'lucky7'].includes(game.id) && <span className="badge hot">🔥 HOT</span>}
      <button 
        className={`favorite-btn ${favorites.includes(game.id) ? 'active' : ''}`}
        onClick={(e) => { e.stopPropagation(); toggleFavorite(game.id); }}
      >
        {favorites.includes(game.id) ? '⭐' : '☆'}
      </button>
      <span className="game-icon">{game.icon}</span>
      <span className="game-name">{language === 'am' ? game.nameAm : game.name}</span>
      <span className="game-min-bet">{game.minBet} ETB</span>
    </div>
  );

  // ─── RENDER GAME VIEW ───
  const renderGameView = () => {
    if (!selectedGame) return null;

    return (
      <div className="game-view">
        <div className="game-view-header">
          <h2 className="game-title">{selectedGame.icon} {language === 'am' ? selectedGame.nameAm : selectedGame.name}</h2>
          <div className="game-stats">
            <span>💰 {formatNumber(balance, language)} ETB</span>
            <span>🎯 {selectedGame.cat.toUpperCase()}</span>
          </div>
        </div>
        <div className="game-area">
          {renderGameSpecificUI(selectedGame.id)}
        </div>
        <div className="game-tutorial">
          <button className="tutorial-btn" onClick={() => showGameTutorial(selectedGame.id)}>
            ℹ️ {language === 'am' ? 'እንዴት መጫወት እንደሚቻል' : 'How to play'}
          </button>
        </div>
      </div>
    );
  };

  // ─── SHOW GAME TUTORIAL ───
  const showGameTutorial = (gameId) => {
    const tutorials = {
      aviator: '📖 Place your bet, watch the multiplier increase, and cash out before it crashes! Higher risk = higher reward.',
      dice: '📖 Roll the dice against the house. Win if your roll is higher than the house roll.',
      coinflip: '📖 Choose heads or tails. Win double your bet if you choose correctly.',
      plinko: '📖 Drop a ball through the pegs. Land in high-multiplier slots for big wins!',
      blackjack: '📖 Get as close to 21 as possible without going over. Beat the dealer to win.',
      roulette: '📖 Bet on red, black, even, or odd. Win 1.9x your bet if you guess correctly.',
      slot: '📖 Spin the reels and match symbols. Three matching symbols = big win!',
      mines: '📖 Click tiles to reveal rewards. Avoid the mines to keep winning.',
      crash: '📖 Watch the multiplier climb and cash out before it crashes!',
      default: '📖 Place your bet and try your luck!'
    };
    
    const tutorial = tutorials[gameId] || tutorials.default;
    showToast(tutorial, 'info');
  };

  // ─── RENDER GAME SPECIFIC UI ───
  const renderGameSpecificUI = (gameId) => {
    switch (gameId) {
      case 'aviator':
        return (
          <div className="aviator-game">
            <canvas ref={canvasRef} className="aviator-canvas" width="400" height="200" />
            <div className="aviator-multiplier" id="aviatorMultiplier">
              {liveGameData.aviator?.multiplier?.toFixed(2) || '1.00'}x
            </div>
            <div className="game-controls">
              <button 
                className="btn-bet"
                onClick={() => playGame('aviator', { action: 'bet' })} 
                disabled={loading || liveGameData.aviator?.gameStarted}
              >
                {loading ? '⏳' : '🎯 Place Bet'}
              </button>
              <button 
                className="btn-cashout"
                onClick={() => playGame('aviator', { action: 'cashout' })}
                disabled={loading || !liveGameData.aviator?.gameStarted}
              >
                💰 Cash Out
              </button>
            </div>
          </div>
        );
      
      case 'dice':
        return (
          <div className="dice-game">
            <div className="dice-display">
              <span id="dicePlayerRoll" className="dice">🎲</span>
              <span className="vs-text">VS</span>
              <span id="diceHouseRoll" className="dice">🎲</span>
            </div>
            <div className="dice-info">
              <span>🎯 Roll higher than the house to win!</span>
            </div>
            <button 
              className="btn-play"
              onClick={() => playGame('dice')}
              disabled={loading}
            >
              {loading ? '⏳ Rolling...' : '🎲 Roll Dice'}
            </button>
          </div>
        );

      case 'coinflip':
        return (
          <div className="coinflip-game">
            <div className="coin-display" id="coinResult">🪙</div>
            <div className="game-controls">
              <button 
                className="btn-bet"
                onClick={() => playGame('coinflip', { side: 'heads' })}
                disabled={loading}
              >
                👑 Heads
              </button>
              <button 
                className="btn-bet"
                onClick={() => playGame('coinflip', { side: 'tails' })}
                disabled={loading}
              >
                🦅 Tails
              </button>
            </div>
          </div>
        );

      case 'plinko':
        return (
          <div className="plinko-game">
            <div className="plinko-multiplier">
              {gameState.plinko?.multiplier ? `${gameState.plinko.multiplier}x` : '1.00x'}
            </div>
            <div className="plinko-grid">
              {/* Plinko grid visualization */}
              <div className="plinko-pegs">
                {Array.from({ length: gameState.plinko?.rows || 12 }).map((_, i) => (
                  <div key={i} className="plinko-row">
                    {Array.from({ length: i + 1 }).map((_, j) => (
                      <span key={j} className="peg">○</span>
                    ))}
                  </div>
                ))}
              </div>
            </div>
            <div className="game-controls">
              <button 
                className="btn-bet"
                onClick={() => playGame('plinko', { rows: 8 })}
              >
                8 Rows
              </button>
              <button 
                className="btn-bet"
                onClick={() => playGame('plinko', { rows: 12 })}
              >
                12 Rows
              </button>
              <button 
                className="btn-bet"
                onClick={() => playGame('plinko', { rows: 16 })}
              >
                16 Rows
              </button>
            </div>
            <button 
              className="btn-play"
              onClick={() => playGame('plinko', { rows: gameState.plinko?.rows || 12 })}
              disabled={loading}
            >
              {loading ? '⏳ Dropping...' : '🔴 Drop Ball'}
            </button>
          </div>
        );

      case 'blackjack':
        return (
          <div className="blackjack-game">
            <div className="bj-display">
              <div className="bj-hand">
                <span className="hand-label">Dealer</span>
                <span id="bjDealer">🂠 🂠</span>
                <span className="hand-score" id="bjDealerScore">0</span>
              </div>
              <div className="bj-hand">
                <span className="hand-label">You</span>
                <span id="bjPlayer">🂠 🂠</span>
                <span className="hand-score" id="bjPlayerScore">0</span>
              </div>
            </div>
            <div className="game-controls">
              <button 
                className="btn-bet"
                onClick={() => playGame('blackjack', { action: 'hit' })}
                disabled={loading || !gameState.blackjack?.playing}
              >
                Hit
              </button>
              <button 
                className="btn-bet"
                onClick={() => playGame('blackjack', { action: 'stand' })}
                disabled={loading || !gameState.blackjack?.playing}
              >
                Stand
              </button>
              <button 
                className="btn-play"
                onClick={() => {
                  setGameState(prev => ({ ...prev, blackjack: { playing: true } }));
                  playGame('blackjack', { action: 'deal' });
                }}
                disabled={loading}
              >
                New Hand
              </button>
            </div>
          </div>
        );

      case 'roulette':
        return (
          <div className="roulette-game">
            <div className="roulette-spin" id="rouletteSpin">🎡</div>
            <div className="roulette-number" id="rouletteNumber">---</div>
            <div className="game-controls">
              <button 
                className="btn-bet red"
                onClick={() => playGame('roulette', { bet: 'red' })}
                disabled={loading}
              >
                🔴 Red
              </button>
              <button 
                className="btn-bet black"
                onClick={() => playGame('roulette', { bet: 'black' })}
                disabled={loading}
              >
                ⚫ Black
              </button>
              <button 
                className="btn-bet even"
                onClick={() => playGame('roulette', { bet: 'even' })}
                disabled={loading}
              >
                Even
              </button>
              <button 
                className="btn-bet odd"
                onClick={() => playGame('roulette', { bet: 'odd' })}
                disabled={loading}
              >
                Odd
              </button>
            </div>
          </div>
        );

      case 'slot':
        return (
          <div className="slot-game">
            <div className="slot-reels">
              <span id="slot1">🎰</span>
              <span id="slot2">🎰</span>
              <span id="slot3">🎰</span>
            </div>
            <button 
              className="btn-play spin"
              onClick={() => {
                playSound('slotSpin');
                playGame('slot');
              }}
              disabled={loading}
            >
              {loading ? '⏳ Spinning...' : '🎰 Spin'}
            </button>
          </div>
        );

      case 'mines':
        return (
          <div className="mines-game">
            <div className="mines-grid">
              {Array.from({ length: 25 }).map((_, i) => (
                <button 
                  key={i} 
                  className={`mine-tile ${gameState.mines?.revealed?.includes(i) ? 'revealed' : ''}`}
                  onClick={() => {
                    if (!gameState.mines?.gameOver) {
                      playGame('mines', { tile: i, mines: 3 });
                    }
                  }}
                  disabled={loading || gameState.mines?.gameOver}
                >
                  {gameState.mines?.revealed?.includes(i) ? (gameState.mines?.mines?.includes(i) ? '💣' : '💰') : '❓'}
                </button>
              ))}
            </div>
            <div className="mines-info">
              <span>💣 Mines: 3 | 💰 Reward: {betAmount * 1.2} ETB</span>
            </div>
          </div>
        );

      case 'crash':
        return (
          <div className="crash-game">
            <div className="crash-multiplier">
              {liveGameData.crash?.multiplier?.toFixed(2) || '1.00'}x
            </div>
            <div className="crash-graph">
              <div className="graph-line"></div>
            </div>
            <div className="game-controls">
              <button 
                className="btn-bet"
                onClick={() => playGame('crash', { action: 'bet' })}
                disabled={loading || liveGameData.crash?.gameStarted}
              >
                📈 Bet
              </button>
              <button 
                className="btn-cashout"
                onClick={() => playGame('crash', { action: 'cashout' })}
                disabled={loading || !liveGameData.crash?.gameStarted}
              >
                💰 Cash Out
              </button>
            </div>
          </div>
        );

      default:
        return (
          <div className="default-game">
            <div className="game-icon-large">{selectedGame?.icon}</div>
            <div className="game-info-text">
              <p>{language === 'am' ? 'ዝግጁ ነዎት? ይጫወቱ!' : 'Ready to play?'}</p>
            </div>
            <button 
              className="btn-play"
              onClick={() => playGame(gameId)}
              disabled={loading}
            >
              {loading ? '⏳ Playing...' : '▶ Play'}
            </button>
          </div>
        );
    }
  };

  // ─── RESULT MODAL ───
  const ResultModal = () => {
    if (!showResultModal || !resultData) return null;

    const isWin = resultData.result === 'win';
    const isLose = resultData.result === 'lose';
    const isPush = resultData.result === 'push';

    return (
      <div className="result-modal-overlay" onClick={() => setShowResultModal(false)}>
        <div className="result-modal">
          <div className="modal-icon">{selectedGame?.icon}</div>
          <h2 className="modal-title">{language === 'am' ? selectedGame?.nameAm : selectedGame?.name}</h2>
          <div className={`result-value ${isWin ? 'win' : isLose ? 'lose' : 'push'}`}>
            {isWin ? `🏆 +${resultData.profit} ETB` : isLose ? `❌ ${resultData.profit} ETB` : '⚖️ Push'}
          </div>
          <div className="result-details">
            <div>{language === 'am' ? 'ውርርድ' : 'Bet'}: <span>{betAmount} ETB</span></div>
            <div>{language === 'am' ? 'ትርፍ' : 'Profit'}: <span className={isWin ? 'green' : isLose ? 'red' : 'yellow'}>{resultData.profit} ETB</span></div>
            <div>{language === 'am' ? 'አዲስ ቀሪ' : 'New Balance'}: <span className="gold">{resultData.newBalance} ETB</span></div>
            {resultData.details && (
              <div className="result-extra">
                {Object.entries(resultData.details).map(([key, value]) => (
                  <div key={key}>{key}: <span>{typeof value === 'object' ? JSON.stringify(value) : value}</span></div>
                ))}
              </div>
            )}
          </div>
          <button className="modal-btn" onClick={() => setShowResultModal(false)}>
            {language === 'am' ? 'ቀጥል' : 'Continue'}
          </button>
        </div>
      </div>
    );
  };

  // ─── BET PANEL ───
  const BetPanel = () => {
    if (!isBetPanelOpen) return null;

    const betAmounts = [1, 2, 5, 10, 20, 50, 100, 500, 1000];
    const quickBetAmounts = [
      { label: '10%', value: Math.round(balance * 0.1) },
      { label: '25%', value: Math.round(balance * 0.25) },
      { label: '50%', value: Math.round(balance * 0.5) },
      { label: '100%', value: Math.round(balance) }
    ];

    return (
      <div className="bet-panel">
        <div className="game-info">
          <span>{selectedGame?.icon} {language === 'am' ? selectedGame?.nameAm : selectedGame?.name}</span>
          <small>{selectedGame?.cat.toUpperCase()} • Min: {selectedGame?.minBet} ETB</small>
        </div>
        
        <div className="quick-bets">
          {quickBetAmounts.map(qb => (
            <button 
              key={qb.label}
              className="quick-bet-btn"
              onClick={() => setBetAmount(Math.max(qb.value, 1))}
              disabled={qb.value < 1}
            >
              {qb.label}
            </button>
          ))}
        </div>

        <div className="bet-amounts">
          {betAmounts.map(amount => (
            <button 
              key={amount}
              className={`amt-btn ${betAmount === amount ? 'active' : ''}`}
              onClick={() => setBetAmount(amount)}
            >
              {amount}
            </button>
          ))}
          <button 
            className="amt-btn max" 
            onClick={() => setBetAmount(Math.min(balance, selectedGame?.maxBet || 10000))}
          >
            MAX
          </button>
        </div>

        <div className="manual-input">
          <input 
            type="number" 
            placeholder="Manual" 
            value={betAmount} 
            onChange={(e) => setBetAmount(Math.max(1, Number(e.target.value)))}
            min="1"
          />
          <span>ETB</span>
        </div>

        <div className="bet-actions">
          <button 
            className="play-btn" 
            onClick={() => playGame(selectedGame?.id)} 
            disabled={loading || betAmount > balance}
          >
            {loading ? '⏳ Loading...' : '▶ Play'}
          </button>
          <button className="close-btn" onClick={() => setIsBetPanelOpen(false)}>✕</button>
        </div>

        <div className="balance-display">
          {language === 'am' ? 'ቀሪ' : 'Balance'}: <strong>{formatNumber(balance, language)} ETB</strong>
        </div>

        {betAmount > balance && (
          <div className="balance-warning">
            ⚠️ {language === 'am' ? 'በቂ ቀሪ የለም' : 'Insufficient balance'}
          </div>
        )}
      </div>
    );
  };

  // ─── RECENT WINNERS ───
  const RecentWinners = () => {
    if (recentWinners.length === 0) return null;

    return (
      <div className="recent-winners">
        <h4>🏆 {language === 'am' ? 'የቅርብ ጊዜ አሸናፊዎች' : 'Recent Winners'}</h4>
        <div className="winners-list">
          {recentWinners.slice(0, 5).map((winner, i) => (
            <div key={i} className="winner-item">
              <span className="winner-icon">🏆</span>
              <span className="winner-name">{winner.username || 'Anonymous'}</span>
              <span className="winner-amount">+{formatNumber(winner.profit, language)} ETB</span>
              <span className="winner-game">{winner.game}</span>
            </div>
          ))}
        </div>
      </div>
    );
  };

  // ─── GAME HISTORY ───
  const GameHistory = () => {
    if (gameHistory.length === 0) return null;

    return (
      <div className="game-history">
        <h4>📊 {language === 'am' ? 'የቅርብ ጊዜ ጨዋታዎች' : 'Recent Games'}</h4>
        <div className="history-list">
          {gameHistory.slice(0, 10).map((game, i) => (
            <div key={i} className={`history-item ${game.result}`}>
              <span className="history-game">{game.gameId}</span>
              <span className="history-bet">{game.bet} ETB</span>
              <span className="history-result">{game.result === 'win' ? '✅' : '❌'}</span>
              <span className={`history-profit ${game.profit >= 0 ? 'positive' : 'negative'}`}>
                {game.profit >= 0 ? '+' : ''}{game.profit} ETB
              </span>
            </div>
          ))}
        </div>
      </div>
    );
  };

  return (
    <div className="casino-games-page">
      {/* Header */}
      <div className="casino-header">
        <div className="header-left">
          <h1>🎰 {language === 'am' ? 'ካዚኖ ጨዋታዎች' : 'Casino Games'}</h1>
          <span className="game-count">{GAMES.length} {language === 'am' ? 'ጨዋታዎች' : 'Games'}</span>
        </div>
        <div className="balance-box">
          <span>💰 {language === 'am' ? 'ቀሪ' : 'Balance'}</span>
          <span className="balance-amount">{formatNumber(balance, language)} ETB</span>
