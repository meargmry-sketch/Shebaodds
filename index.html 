  // ─── GAME LOGIC ───
  const gameLogic = {
    dice: (bet, params) => {
      const playerRoll = Math.floor(Math.random() * 6) + 1;
      const houseRoll = Math.floor(Math.random() * 6) + 1;
      const win = playerRoll > houseRoll;
      return {
        result: win ? 'win' : 'lose',
        profit: win ? bet * 2 : -bet,
        details: { playerRoll, houseRoll, win }
      };
    },

    coinflip: (bet, params) => {
      const result = Math.random() < 0.5 ? 'heads' : 'tails';
      const win = params.side === result;
      return {
        result: win ? 'win' : 'lose',
        profit: win ? bet * 1.9 : -bet,
        details: { result, side: params.side }
      };
    },

    plinko: (bet, params) => {
      const rows = params.rows || 12;
      const multipliers = {
        8: [5.6, 2.1, 1.1, 1.0, 1.0, 1.1, 2.1, 5.6],
        12: [10, 5, 3, 1.5, 0.5, 0.5, 0.5, 0.5, 1.5, 3, 5, 10],
        16: [29, 10, 5, 2, 1, 0.5, 0.3, 0.3, 0.3, 0.3, 0.5, 1, 2, 5, 10, 29]
      };
      const multiplier = multipliers[rows]?.[Math.floor(Math.random() * rows)] || 1;
      const profit = bet * multiplier - bet;
      return {
        result: profit > 0 ? 'win' : 'lose',
        profit: Math.round(profit * 100) / 100,
        details: { multiplier, rows }
      };
    },

    roulette: (bet, params) => {
      const number = Math.floor(Math.random() * 37);
      const reds = [1,3,5,7,9,12,14,16,18,19,21,23,25,27,30,32,34,36];
      const isRed = reds.includes(number);
      const isEven = number > 0 && number % 2 === 0;
      
      let win = false;
      let multiplier = 0;
      
      switch(params.bet) {
        case 'red': win = isRed; multiplier = 1.9; break;
        case 'black': win = !isRed && number !== 0; multiplier = 1.9; break;
        case 'even': win = isEven; multiplier = 1.9; break;
        case 'odd': win = !isEven && number !== 0; multiplier = 1.9; break;
        default: win = false; multiplier = 0;
      }
      
      const profit = win ? bet * multiplier : -bet;
      return {
        result: win ? 'win' : 'lose',
        profit: Math.round(profit * 100) / 100,
        details: { number, isRed, isEven, bet: params.bet }
      };
    },

    slot: (bet, params) => {
      const symbols = ['🍒', '🍋', '🍊', '🍇', '💎', '7️⃣', '🎰'];
      const reels = [
        symbols[Math.floor(Math.random() * symbols.length)],
        symbols[Math.floor(Math.random() * symbols.length)],
        symbols[Math.floor(Math.random() * symbols.length)]
      ];
      
      // Check for wins
      let win = false;
      let multiplier = 0;
      
      if (reels[0] === reels[1] && reels[1] === reels[2]) {
        win = true;
        const symbolIndex = symbols.indexOf(reels[0]);
        multiplier = symbolIndex + 1;
      } else if (reels[0] === reels[1] || reels[1] === reels[2] || reels[0] === reels[2]) {
        win = true;
        multiplier = 0.5;
      }
      
      const profit = win ? bet * multiplier : -bet;
      return {
        result: win ? 'win' : 'lose',
        profit: Math.round(profit * 100) / 100,
        details: { reels, multiplier: Math.round(multiplier * 100) / 100 }
      };
    },

    blackjack: (bet, params) => {
      const getCard = () => {
        const value = Math.floor(Math.random() * 13) + 1;
        return { value: Math.min(value, 10), display: value };
      };
      
      const playerCards = [getCard(), getCard()];
      const dealerCards = [getCard(), getCard()];
      
      const score = (cards) => {
        let total = cards.reduce((sum, c) => sum + c.value, 0);
        const aces = cards.filter(c => c.display === 1).length;
        while (total <= 11 && aces > 0) {
          total += 10;
        }
        return total;
      };
      
      const playerScore = score(playerCards);
      const dealerScore = score(dealerCards);
      
      let result = 'lose';
      let profit = -bet;
      
      if (playerScore === 21 && playerCards.length === 2) {
        result = 'win';
        profit = bet * 2.5; // Blackjack pays 3:2
      } else if (playerScore > 21) {
        result = 'lose';
        profit = -bet;
      } else if (dealerScore > 21) {
        result = 'win';
        profit = bet;
      } else if (playerScore > dealerScore) {
        result = 'win';
        profit = bet;
      } else if (playerScore === dealerScore) {
        result = 'push';
        profit = 0;
      }
      
      return {
        result,
        profit: Math.round(profit * 100) / 100,
        details: { playerCards: playerCards.map(c => c.display), dealerCards: dealerCards.map(c => c.display), playerScore, dealerScore }
      };
    },

    aviator: (bet, params) => {
      const crashPoint = 1 + Math.random() * 9; // 1.0 - 10.0
      const cashOut = params.action === 'cashout' ? Math.min(1 + Math.random() * 5, crashPoint) : 0;
      const win = params.action === 'cashout' && cashOut < crashPoint;
      const multiplier = win ? cashOut : 0;
      const profit = win ? bet * multiplier : -bet;
      
      return {
        result: win ? 'win' : 'lose',
        profit: Math.round(profit * 100) / 100,
        details: { crashPoint: Math.round(crashPoint * 100) / 100, multiplier: Math.round(multiplier * 100) / 100 }
      };
    },

    mines: (bet, params) => {
      const gridSize = 25;
      const mineCount = params.mines || 3;
      const mines = [];
      const revealed = [];
      
      while (mines.length < mineCount) {
        const pos = Math.floor(Math.random() * gridSize);
        if (!mines.includes(pos)) mines.push(pos);
      }
      
      // Simulate revealing a random tile
      let hitMine = false;
      let tile = Math.floor(Math.random() * gridSize);
      if (mines.includes(tile)) {
        hitMine = true;
      }
      revealed.push(tile);
      
      const profit = hitMine ? -bet : bet * (1 + (gridSize - mineCount) / gridSize);
      
      return {
        result: hitMine ? 'lose' : 'win',
        profit: Math.round(profit * 100) / 100,
        details: { mines, revealed, hitMine }
      };
    },

    crash: (bet, params) => {
      const crashPoint = 1 + Math.random() * 9;
      const cashOut = params.cashOut || false;
      const multiplier = cashOut ? Math.min(1 + Math.random() * 5, crashPoint) : 0;
      const win = cashOut && multiplier < crashPoint;
      const profit = win ? bet * multiplier : -bet;
      
      return {
        result: win ? 'win' : 'lose',
        profit: Math.round(profit * 100) / 100,
        details: { crashPoint: Math.round(crashPoint * 100) / 100, multiplier: Math.round(multiplier * 100) / 100 }
      };
    },

    default: (bet, params) => {
      const win = Math.random() < 0.45;
      const profit = win ? bet * 1.9 : -bet;
      return {
        result: win ? 'win' : 'lose',
        profit: Math.round(profit * 100) / 100,
        details: {}
      };
    }
  };

  // ─── PLAY GAME ───
  const playGame = async (gameId, params = {}) => {
    if (!user) {
      showToast('Please login to play games', 'error');
      navigate('/login');
      return;
    }

    const game = GAMES.find(g => g.id === gameId);
    if (!game) return;

    if (betAmount < game.minBet) {
      showToast(`Minimum bet is ${game.minBet} ETB`, 'warning');
      return;
    }

    if (betAmount > game.maxBet) {
      showToast(`Maximum bet is ${game.maxBet} ETB`, 'warning');
      return;
    }

    if (betAmount > balance) {
      showToast(`Insufficient balance. Your balance is ${formatNumber(balance, language)} ETB`, 'error');
      return;
    }

    setLoading(true);
    try {
      // Try server-side game execution first
      let response;
      try {
        response = await axios.post('/api/games/play', {
          gameId,
          bet: betAmount,
          params,
          userId: user.id
        });
      } catch (serverError) {
        // Fallback to client-side game logic if server is unavailable
        console.warn('Server unavailable, using client-side game logic');
        const logic = gameLogic[gameId] || gameLogic.default;
        const result = logic(betAmount, params);
        response = {
          data: {
            ...result,
            newBalance: balance + result.profit,
            gameId
          }
        };
      }

      const data = response.data;
      setBalance(data.newBalance);
      
      // Update parent balance if available
      if (updateBalance) {
        updateBalance(data.newBalance);
      }
      
      // Show result modal
      setResultData(data);
      setShowResultModal(true);

      // Add to history
      setGameHistory(prev => [{
        gameId,
        bet: betAmount,
        result: data.result,
        profit: data.profit,
        details: data.details,
        timestamp: new Date()
      }, ...prev].slice(0, 50));

      // Play sound
      if (data.result === 'win') {
        playSound('win');
      } else if (data.result === 'lose') {
        playSound('lose');
      }

      // Update game view
      updateGameView(gameId, data);

    } catch (error) {
      const errorMessage = error.response?.data?.error || 
                          error.response?.data?.message || 
                          'Failed to play game. Please try again.';
      showToast(errorMessage, 'error');
    } finally {
      setLoading(false);
    }
