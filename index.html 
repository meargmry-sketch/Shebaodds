  // ─── SOUND EFFECTS ───
  const sounds = {
    win: new Audio('/sounds/win.mp3'),
    lose: new Audio('/sounds/lose.mp3'),
    spin: new Audio('/sounds/spin.mp3'),
    coinFlip: new Audio('/sounds/coin.mp3'),
    diceRoll: new Audio('/sounds/dice.mp3'),
    slotSpin: new Audio('/sounds/slot.mp3')
  };

  const playSound = (type) => {
    if (sounds[type]) {
      sounds[type].currentTime = 0;
      sounds[type].play().catch(() => {});
    }
  };

  // ─── UPDATE AVIATOR MULTIPLIER ───
  const updateAviatorMultiplier = (multiplier) => {
    const canvas = canvasRef.current;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    
    // Clear canvas
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    // Draw background
    ctx.fillStyle = '#1a1f33';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    
    // Draw multiplier
    ctx.fillStyle = '#f0b90b';
    ctx.font = 'bold 48px Arial';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(`${multiplier.toFixed(2)}x`, canvas.width/2, canvas.height/2);
    
    // Draw graph line
    ctx.beginPath();
    ctx.moveTo(0, canvas.height);
    const points = 50;
    for (let i = 0; i < points; i++) {
      const x = (i / points) * canvas.width;
      const y = canvas.height - (Math.min(multiplier, 5) / 5) * canvas.height * (i / points);
      ctx.lineTo(x, y);
    }
    ctx.strokeStyle = '#f0b90b';
    ctx.lineWidth = 2;
    ctx.stroke();
  };

  // ─── OPEN GAME ───
  const openGame = (game) => {
    setSelectedGame(game);
    setIsBetPanelOpen(true);
    initGameState(game.id);
    // Scroll to game view
    setTimeout(() => {
      document.querySelector('.game-view')?.scrollIntoView({ behavior: 'smooth' });
