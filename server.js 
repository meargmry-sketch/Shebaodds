  if (amount > balance) return res.status(400).json({ error: 'Insufficient balance' });
  pendingWithdrawals.push({ ticket, amount, status: 'pending', timestamp: Date.now() });
  res.json({ message: 'Withdraw request submitted', ticket, amount });
});

// ─── Admin endpoints ──────────────────────────────────────────────
app.get('/api/admin/pending-deposits', (req, res) => res.json(pendingDeposits.filter(d => d.status === 'pending')));
app.get('/api/admin/pending-withdrawals', (req, res) => res.json(pendingWithdrawals.filter(w => w.status === 'pending')));
app.post('/api/admin/approve-deposit', (req, res) => {
  const { ticket } = req.body;
  const deposit = pendingDeposits.find(d => d.ticket === ticket && d.status === 'pending');
  if (!deposit) return res.status(404).json({ error: 'Not found' });
  deposit.status = 'approved';
  balance += deposit.amount;
  res.json({ message: 'Deposit approved', newBalance: balance });
});
app.post('/api/admin/approve-withdrawal', (req, res) => {
  const { ticket } = req.body;
  const withdrawal = pendingWithdrawals.find(w => w.ticket === ticket && w.status === 'pending');
  if (!withdrawal) return res.status(404).json({ error: 'Not found' });
  if (withdrawal.amount > balance) return res.status(400).json({ error: 'Insufficient balance' });
  withdrawal.status = 'approved';
  balance -= withdrawal.amount;
  res.json({ message: 'Withdrawal approved', newBalance: balance });
});
app.post('/api/admin/reject', (req, res) => {
  const { ticket, type } = req.body;
  const list = type === 'deposit' ? pendingDeposits : pendingWithdrawals;
  const item = list.find(x => x.ticket === ticket && x.status === 'pending');
  if (!item) return res.status(404).json({ error: 'Not found' });
  item.status = 'rejected';
  res.json({ message: 'Transaction rejected' });
});

app.listen(port, () => console.log(`Server running on port ${port}`));